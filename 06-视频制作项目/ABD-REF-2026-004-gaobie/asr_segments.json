{
  "language": "zh",
  "duration": 141.628,
  "segments": [
    {
      "start": 0.0,
      "end": 1.44,
      "text": "我出了"
    },
    {
      "start": 1.44,
      "end": 3.8,
      "text": "让黄彩给你写"
    },
    {
      "start": 3.8,
      "end": 13.48,
      "text": "你从我脚过嘴从明的学生"
    },
    {
      "start": 13.48,
      "end": 15.4,
      "text": "嘴有希望都是嘴的三钩钩"
    },
    {
      "start": 15.4,
      "end": 17.28,
      "text": "老四傻瓜也就逮不了你了"
    },
    {
      "start": 17.28,
      "end": 18.44,
      "text": "这是你的作业"
    },
    {
      "start": 18.44,
      "end": 19.84,
      "text": "我屁该玩了"
    },
    {
      "start": 19.84,
      "end": 20.64,
      "text": "好好靠"
    },
    {
      "start": 20.64,
      "end": 21.88,
      "text": "别让老四死亡"
    },
    {
      "start": 21.88,
      "end": 29.1,
      "text": "大雪"
    },
    {
      "start": 29.1,
      "end": 30.78,
      "text": "我 我不起了"
    },
    {
      "start": 30.78,
      "end": 32.5,
      "text": "都回来 我一定娶你"
    },
    {
      "start": 32.5,
      "end": 43.47,
      "text": "二门少年 快起来"
    },
    {
      "start": 44.59,
      "end": 46.11,
      "text": "你太失败了"
    },
    {
      "start": 46.11,
      "end": 47.27,
      "text": "甭定不是说笑"
    },
    {
      "start": 47.27,
      "end": 48.55,
      "text": "我总得变换几倍感了"
    },
    {
      "start": 48.55,
      "end": 49.35,
      "text": "走吧"
    },
    {
      "start": 49.35,
      "end": 77.9,
      "text": "老师说"
    },
    {
      "start": 78.02,
      "end": 80.46,
      "text": "天上的人会变成星星"
    },
    {
      "start": 80.46,
      "end": 83.59,
      "text": "爸"
    },
    {
      "start": 83.59,
      "end": 85.43,
      "text": "爸 怎么在发呆"
    },
    {
      "start": 85.43,
      "end": 86.59,
      "text": "爸 我要走了"
    },
    {
      "start": 86.59,
      "end": 87.43,
      "text": "爸"
    },
    {
      "start": 87.43,
      "end": 88.83,
      "text": "我会照顾好他的"
    }
  ]
}