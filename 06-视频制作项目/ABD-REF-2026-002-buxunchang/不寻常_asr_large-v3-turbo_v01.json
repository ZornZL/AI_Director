  "segments": [
    {
      "start": 0.37,
      "end": 1.17,
      "text": "破鞭致的窝囊"
    },
    {
      "start": 1.17,
      "end": 6.26,
      "text": "你们单位的老王"
    },
    {
      "start": 6.26,
      "end": 7.24,
      "text": "当初追我的时候"
    },
    {
      "start": 7.24,
      "end": 8.02,
      "text": "我都没同意"
    },
    {
      "start": 8.02,
      "end": 9.74,
      "text": "人家现在是局长了"
    },
    {
      "start": 9.74,
      "end": 10.9,
      "text": "女儿在美国留学"
    },
    {
      "start": 10.9,
      "end": 12.57,
      "text": "你二十年"
    },
    {
      "start": 12.57,
      "end": 14.83,
      "text": "现在连你儿子"
    },
    {
      "start": 14.83,
      "end": 15.67,
      "text": "你那个破铁饭碗"
    },
    {
      "start": 15.67,
      "end": 18.7,
      "text": "早知道这样"
    },
    {
      "start": 18.7,
      "end": 20.14,
      "text": "还不如当初冒险"
    },
    {
      "start": 20.14,
      "end": 20.98,
      "text": "去捞点偏门"
    },
    {
      "start": 20.98,
      "end": 22.1,
      "text": "捞偏门"
    },
    {
      "start": 22.1,
      "end": 23.84,
      "text": "结果把自己给捞进来了"
    },
    {
      "start": 23.84,
      "end": 25.92,
      "text": "在这个鬼地方待十年"
    },
    {
      "start": 25.92,
      "end": 27.91,
      "text": "要知道今天这个下场"
    },
    {
      "start": 27.91,
      "end": 29.89,
      "text": "当初还不如下海去创业"
    },
    {
      "start": 29.89,
      "end": 30.81,
      "text": "创业"
    },
    {
      "start": 30.81,
      "end": 32.98,
      "text": "贷款了五百万"
    },
    {
      "start": 32.98,
      "end": 34.1,
      "text": "全部砸进去了"
    },
    {
      "start": 34.1,
      "end": 35.7,
      "text": "房子抵押了"
    },
    {
      "start": 35.7,
      "end": 37.08,
      "text": "老婆离婚带着孩子走了"
    },
    {
      "start": 37.08,
      "end": 38.82,
      "text": "早知道这样"
    },
    {
      "start": 38.82,
      "end": 40.78,
      "text": "当初还不如老老实实去打工"
    },
    {
      "start": 40.78,
      "end": 42.74,
      "text": "不能再熬了"
    },
    {
      "start": 42.74,
      "end": 44.1,
      "text": "再熬就猝死了"
    },
    {
      "start": 44.1,
      "end": 44.98,
      "text": "打工"
    },
    {
      "start": 44.98,
      "end": 46.85,
      "text": "天天九九六"
    },
    {
      "start": 46.85,
      "end": 47.69,
      "text": "卷来卷去"
    },
    {
      "start": 47.69,
      "end": 49.65,
      "text": "卷到差点把命搭进去"
    },
    {
      "start": 49.65,
      "end": 50.67,
      "text": "与其这样"
    },
    {
      "start": 50.67,
      "end": 53.05,
      "text": "还不如回老家躺平算了"
    },
    {
      "start": 53.05,
      "end": 53.89,
      "text": "回老家躺平"
    },
    {
      "start": 53.89,
      "end": 55.38,
      "text": "想干就干"
    },
    {
      "start": 55.38,
      "end": 56.18,
      "text": "不想干就休息"
    },
    {
      "start": 56.18,
      "end": 57.46,
      "text": "一个人吃饱全家不饿"
    },
    {
      "start": 57.46,
      "end": 58.84,
      "text": "这个月赚三千"
    },
    {
      "start": 58.84,
      "end": 60.48,
      "text": "可能下个月靠信用卡活着"
    },
    {
      "start": 60.48,
      "end": 61.78,
      "text": "社保断了三个月"
    },
    {
      "start": 61.78,
      "end": 62.6,
      "text": "住在父母家"
    },
    {
      "start": 62.6,
      "end": 63.42,
      "text": "天天被催婚"
    },
    {
      "start": 63.42,
      "end": 64.06,
      "text": "被骂啃老"
    },
    {
      "start": 64.06,
      "end": 65.5,
      "text": "要是找个人一起奋斗"
    },
    {
      "start": 65.5,
      "end": 66.54,
      "text": "搭伙过日子就好了"
    },
    {
      "start": 66.54,
      "end": 68.42,
      "text": "你都多大了还不嫁人"
    },
    {
      "start": 68.42,
      "end": 69.44,
      "text": "想啃老一辈子吗"
    },
    {
      "start": 69.44,
      "end": 70.38,
      "text": "打伙过日子"
    },
    {
      "start": 70.38,
      "end": 72.21,
      "text": "每个月车贷房贷"
    },
    {
      "start": 72.21,
      "end": 73.13,
      "text": "还有孩子的奶粉"
    },
    {
      "start": 73.13,
      "end": 73.85,
      "text": "尿不湿的费用"
    },
    {
      "start": 73.85,
      "end": 75.39,
      "text": "压的人连气都喘不过来"
    },
    {
      "start": 75.39,
      "end": 77.03,
      "text": "与其两个人"
    },
    {
      "start": 77.03,
      "end": 78.01,
      "text": "带着孩子一起受苦"
    },
    {
      "start": 78.01,
      "end": 79.29,
      "text": "还不如当初找个"
    },
    {
      "start": 79.29,
      "end": 80.71,
      "text": "真心喜欢我的有钱人嫁了"
    },
    {
      "start": 80.71,
      "end": 83.07,
      "text": "有的人就是命好"
    },
    {
      "start": 83.07,
      "end": 84.17,
      "text": "嫁进来就当少奶奶"
    },
    {
      "start": 84.17,
      "end": 85.41,
      "text": "想当年我们年轻那时候"
    },
    {
      "start": 85.41,
      "end": 86.13,
      "text": "伺候公婆"
    },
    {
      "start": 86.13,
      "end": 86.65,
      "text": "上班赚钱"
    },
    {
      "start": 86.65,
      "end": 87.09,
      "text": "下班带娃"
    },
    {
      "start": 87.09,
      "end": 87.79,
      "text": "哪样少得了"
    },
    {
      "start": 87.79,
      "end": 88.71,
      "text": "嫁个有钱人"
    },
    {
      "start": 88.71,
      "end": 89.87,
      "text": "她是对我好"
    },
    {
      "start": 89.87,
      "end": 91.65,
      "text": "可婆婆天天指桑骂怀"
    },
    {
      "start": 91.65,
      "end": 93.13,
      "text": "挖着她儿子的钱"
    },
    {
      "start": 93.13,
      "end": 94.31,
      "text": "就得看他们家人的脸色"
    },
    {
      "start": 94.31,
      "end": 95.85,
      "text": "人在屋檐下不得不低头"
    },
    {
      "start": 95.85,
      "end": 97.23,
      "text": "早知道这样"
    },
    {
      "start": 97.23,
      "end": 98.47,
      "text": "当初就不该辞掉"
    },
    {
      "start": 98.47,
      "end": 99.33,
      "text": "那个有编制的工作"
    },
    {
      "start": 99.33,
      "end": 99.89,
      "text": "编制"
    },
    {
      "start": 99.89,
      "end": 101.25,
      "text": "这份安稳"
    },
    {
      "start": 101.25,
      "end": 103.35,
      "text": "真的适合所有人吗"
    },
    {
      "start": 103.35,
      "end": 111.85,
      "text": "建国同志"
    },
    {
      "start": 111.85,
      "end": 113.67,
      "text": "十五年如一日本份工作"
    },
    {
      "start": 113.67,
      "end": 114.45,
      "text": "经得起茶"
    },
    {
      "start": 114.45,
      "end": 115.51,
      "text": "也经得起考验"
    },
    {
      "start": 115.51,
      "end": 117.76,
      "text": "根据你退还全部款项"
    },
    {
      "start": 117.76,
      "end": 118.62,
      "text": "主动交代问题"
    },
    {
      "start": 118.62,
      "end": 119.56,
      "text": "并配合调查的期望"
    },
    {
      "start": 119.56,
      "end": 120.62,
      "text": "经研究决定"
    },
    {
      "start": 120.62,
      "end": 121.46,
      "text": "你的服刑期限"
    },
    {
      "start": 121.46,
      "end": 122.5,
      "text": "由十年调整为两年"
    },
    {
      "start": 122.5,
      "end": 123.9,
      "text": "今天就可以办理手续了"
    },
    {
      "start": 123.9,
      "end": 125.44,
      "text": "出去以后"
    },
    {
      "start": 125.44,
      "end": 126.28,
      "text": "好好过日子"
    },
    {
      "start": 126.28,
